APP_NAME=craveva
APP_KEY=base64:wID/CO/WkfE3yoWpQOoy15de8FtOpvC3dM/z5FuHiEU=

# Do not change APP_ENV to anything else. It will affect emailing from admin panel
# and other configuration from databse and system may crash
APP_ENV=craveva
APP_DEBUG=false

# Import UI polls may run queue:work when APP_ENV is local/development, or APP_URL looks like local dev
# (localhost / *.test), or IMPORT_PROGRESS_RUN_QUEUE_WORKER=true. Staging/production: use Supervisor; set
# IMPORT_PROGRESS_RUN_QUEUE_WORKER=false if you need to force-disable inline worker.
# Staging without Supervisor: set true so each import poll can run queue:work (keeps progress moving).
# IMPORT_PROGRESS_RUN_QUEUE_WORKER=true
# IMPORT_PROGRESS_EXECUTION_JOBS_PER_POLL=8
# Cap seconds of queue:work per poll (avoids nginx timeout on large Client import). 0 = no cap.
# IMPORT_PROGRESS_WORKER_MAX_SECONDS=25
# IMPORT_PROGRESS_RUN_QUEUE_WORKER_ENVIRONMENTS=local,development,craveva

APP_URL=http://localhost

#For redirect to https
REDIRECT_HTTPS=false

MAIL_FROM_VERIFIED_EMAIL=true

# Add here if you main app is installed on some subdomain
MAIN_APPLICATION_SUBDOMAIN=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Queue: default sync/local. Production often database or redis.
# QUEUE_CONNECTION=database
#
# Redis — cùng một repo git cho local / staging / hub: file .env KHÔNG commit; giữ ĐỒNG BỘ TÊN biến
# (REDIS_HOST, REDIS_PORT, …). Mỗi máy thường Redis riêng 127.0.0.1:6379. Prefix key Laravel = slug(APP_NAME) + "_database_"
# — nên APP_NAME (hoặc REDIS_PREFIX) khác nhau giữa môi trường nếu bao giờ trỏ chung một Redis.
# Local Windows: thường chưa cài Redis → để QUEUE_CONNECTION=database. Cài Redis (hoặc Docker) rồi bật các dòng dưới.
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1
# CACHE_DRIVER=file
# SESSION_DRIVER=file
#
# Import Bus::batch jobs: default database. Set to redis after Redis + php-redis + worker:
#   php artisan queue:work redis --queue=ClientImport,ProductImport,...
# Schedule (Kernel) splits: database worker for `default`, redis worker for import queues when connection is redis.
# IMPORT_BATCH_QUEUE_CONNECTION=database
#
# Client import chunk size (rows per ImportClientChunkJob). Default 150 in config/import.php.
# CLIENT_IMPORT_CHUNK_SIZE=150

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Warehouse module — Scope B sales outbound (see Modules/Warehouse/Config/config.php)
# WAREHOUSE_SALES_OUTBOUND_ENABLED=true
# WAREHOUSE_SALES_OUTBOUND_MODE=shipment
# WAREHOUSE_INBOUND_FROM_PO_DELIVERED=true
# WAREHOUSE_INBOUND_FROM_DO_RECEIVED=false

# Purchase flow compatibility/cutover flags
# PURCHASE_FLOW_NAMING_MODE=compat_v2
# PURCHASE_DO_GRN_CUTOVER_ENABLED=false
