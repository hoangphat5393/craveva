%% Bản rút gọn — đồng bộ với FUNC_LOGIC/QUY_TRINH + SALES_PURCHASE_FLOW (2026-04).
%% Chi tiết ledger + idempotency: pis_e2e_current.mmd

graph TD
  subgraph mua [Mua hàng và nhập kho]
    A[PO] --> B{Inbound chuẩn tenant}
    B -->|PO delivered + flag| I[(Tồn / batches)]
    B -->|GRN received + flag| I
    POINV[Purchase Inventory adjust] --> I
    F[PurchaseBill — AP] -.->|không ghi stock_movements| G[Công nợ NCC]
    VC[Vendor Credit] -.->|giảm AP; chưa gắn xuất kho tự động trong code| G
  end

  subgraph ban [Bán và xuất kho]
    J[SO / Order] --> K[Sales DO]
    K --> L[Confirm DO — reservation]
    L --> M[Ship DO — outbound nếu mode shipment]
    M --> I
    J -.-> N[Sales Invoice — AR]
    N -.->|mode invoice: outbound từ HĐ| I
    N --> CN[Credit Note — trả hàng]
    CN -->|recordInbound| I
  end

  subgraph kho [Sổ cái]
    SM[(stock_movements)]
    I --> SM
  end
