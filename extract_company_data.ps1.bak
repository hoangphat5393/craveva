param(
  [string]$CompanyName = "Cravava AI",
  [int]$CompanyIdOverride,
  [string]$SourceEnvPath = ".\.env",
  [string]$SourceSqlFile,
  [string]$TempDbName = "staging_tmp",
  [string]$SourceHost,
  [int]$SourcePort = 3306,
  [string]$SourceDb,
  [string]$SourceUser,
  [string]$SourcePass,
  [string]$OutputDb = "cravava_ai",
  [string]$OutputSql = "cravava_ai_extract.sql",
  [string]$LogFile = "extract_company.log"
)

$ErrorActionPreference = "Stop"

function Get-EnvVars {
  param([string]$path)
  $vars = @{}
  if (Test-Path $path) {
    Get-Content $path | ForEach-Object {
      if ($_ -match '^\s*DB_(HOST|PORT|DATABASE|USERNAME|PASSWORD)\s*=\s*(.+)\s*$') {
        $k = $matches[1]
        $v = $matches[2].Trim('"').Trim("'")
        $vars["DB_$k"] = $v
      }
    }
  }
  return $vars
}

function Ensure-Command {
  param([string]$name)
  try { Get-Command $name -ErrorAction Stop | Out-Null } catch { throw "$name not found" }
}

function Import-SqlDump {
  param([string]$sqlFile,[string]$db,[string]$user,[string]$pass)
  if (-not (Test-Path $sqlFile)) { throw "SQL file not found: $sqlFile" }
  Write-Host "Preparing temp database '$db'..."
  $ddl = ("DROP DATABASE IF EXISTS `{0}`; CREATE DATABASE `{0}` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" -f $db)
  $createCmd = "mysql -u $user -e `"$ddl`""
  if ($pass -and $pass -ne "") { $createCmd = "mysql -u $user -p$pass -e `"$ddl`"" }
  cmd /c $createCmd
  if ($LASTEXITCODE -ne 0) { throw "Failed to create temp database $db" }
  Write-Host "Importing $sqlFile into $db..."
  $importCmd = "mysql -u $user $db < `"$sqlFile`""
  if ($pass -and $pass -ne "") { $importCmd = "mysql -u $user -p$pass $db < `"$sqlFile`"" }
  cmd /c $importCmd
  if ($LASTEXITCODE -ne 0) { throw "Failed to import SQL dump into $db" }
  Write-Host "Import completed." -ForegroundColor Green
}

function Build-MySqlArgs {
  param([string]$dbHost,[int]$dbPort,[string]$dbUser,[string]$dbPass,[string]$dbName)
  $args = @("--batch","--raw","--skip-column-names","-h",$dbHost,"-P",$dbPort.ToString()," -u",$dbUser)
  if ($dbPass -ne $null -and $dbPass -ne "") { $args += "-p$dbPass" }
  if ($dbName -and $dbName -ne "") { $args += $dbName }
  return $args
}

function Invoke-MySql {
  param([string]$sql,[string]$dbHost,[int]$dbPort,[string]$dbUser,[string]$dbPass,[string]$dbName)
  $args = Build-MySqlArgs -dbHost $dbHost -dbPort $dbPort -dbUser $dbUser -dbPass $dbPass -dbName $dbName
  $args += @("-e",$sql)
  $p = Start-Process -FilePath "mysql" -ArgumentList $args -NoNewWindow -RedirectStandardOutput "STDOUT.tmp" -RedirectStandardError "STDERR.tmp" -PassThru -Wait
  if ($p.ExitCode -ne 0) {
    $err = $null
    if (Test-Path "STDERR.tmp") { try { $err = Get-Content "STDERR.tmp" -Raw } catch { $err = $null } }
    $out = $null
    if (Test-Path "STDOUT.tmp") { try { $out = Get-Content "STDOUT.tmp" -Raw } catch { $out = $null } }
    Remove-Item "STDOUT.tmp","STDERR.tmp" -Force -ErrorAction SilentlyContinue
    $errText = ""
    if ($null -ne $err) { $errText = $err.Trim() }
    $outText = ""
    if ($null -ne $out) { $outText = $out.Trim() }
    $msg = "MySQL error"
    if ($errText.Length -gt 0) { $msg += ": $errText" }
    elseif ($outText.Length -gt 0) { $msg += " (stdout=$outText)" }
    else { $msg += " (exitCode=$($p.ExitCode)) while executing: $sql" }
    throw $msg
  }
  $out = Get-Content "STDOUT.tmp"
  Remove-Item "STDOUT.tmp","STDERR.tmp" -Force
  return $out
}

function Build-DumpArgs {
  param([string]$dbHost,[int]$dbPort,[string]$dbUser,[string]$dbPass,[string]$dbName)
  $args = @("--no-tablespaces","--single-transaction","--skip-add-locks","--skip-set-charset","--skip-triggers","-h",$dbHost,"-P",$dbPort.ToString()," -u",$dbUser)
  if ($dbPass -ne $null -and $dbPass -ne "") { $args += "-p$dbPass" }
  $args += $dbName
  return $args
}

function Append-Mysqldump {
  param([string]$table,[string]$where,[string]$dbHost,[int]$dbPort,[string]$dbUser,[string]$dbPass,[string]$dbName,[string]$outFile,[switch]$StructureOnly)
  $args = Build-DumpArgs -dbHost $dbHost -dbPort $dbPort -dbUser $dbUser -dbPass $dbPass -dbName $dbName
  if ($StructureOnly) { $args = @("--no-data") + $args + @($table) }
  else {
    if ($where -and $where -ne "") { $args = @("--complete-insert","--extended-insert","--where=$where") + $args + @($table) }
    else { $args = @("--complete-insert","--extended-insert") + $args + @($table) }
  }
  $p = Start-Process -FilePath "mysqldump" -ArgumentList $args -NoNewWindow -RedirectStandardOutput "DUMP.tmp" -RedirectStandardError "DUMPERR.tmp" -PassThru -Wait
  if ($p.ExitCode -ne 0) {
    $err = Get-Content "DUMPERR.tmp" -Raw
    Remove-Item "DUMP.tmp","DUMPERR.tmp" -Force
    throw "mysqldump error: $err"
  }
  Get-Content "DUMP.tmp" | Out-File -FilePath $outFile -Append -Encoding ASCII
  Remove-Item "DUMP.tmp","DUMPERR.tmp" -Force
}

$TranscriptStarted = $false
try { Start-Transcript -Path $LogFile -Force | Out-Null; $TranscriptStarted = $true } catch { }
Ensure-Command "mysql"
Ensure-Command "mysqldump"

# If a SQL dump file is provided, import it into a temp database locally
if ($SourceSqlFile -and $SourceSqlFile -ne "") {
  $evLocal = Get-EnvVars -path $SourceEnvPath
  if (-not $SourceUser -or $SourceUser -eq "") { $SourceUser = $evLocal.DB_USERNAME; if (-not $SourceUser) { $SourceUser = "root" } }
  if (-not $SourcePass) { $SourcePass = $evLocal.DB_PASSWORD }
  $SourceHost = "127.0.0.1"
  $SourcePort = 3306
  $SourceDb = $TempDbName
  Import-SqlDump -sqlFile $SourceSqlFile -db $TempDbName -user $SourceUser -pass $SourcePass
}
elseif (-not $SourceHost -or -not $SourceDb -or -not $SourceUser) {
  $ev = Get-EnvVars -path $SourceEnvPath
  if (-not $SourceHost) { $SourceHost = $ev.DB_HOST }
  if (-not $SourcePort -or $SourcePort -eq 0) { if ($ev.DB_PORT) { $SourcePort = [int]$ev.DB_PORT } }
  if (-not $SourceDb) { $SourceDb = $ev.DB_DATABASE }
  if (-not $SourceUser) { $SourceUser = $ev.DB_USERNAME }
  if (-not $SourcePass) { $SourcePass = $ev.DB_PASSWORD }
}

Write-Host ("Source {0}:{1}/{2}" -f $SourceHost, $SourcePort, $SourceDb)
Write-Host "Resolving company id for '$CompanyName'"
$cn = $CompanyName.Replace("'","\\'")
# Ensure 'companies' table exists in imported dump
$tblExists = Invoke-MySql -sql "SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='$SourceDb' AND table_name='companies'" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
if ([int]($tblExists[0]) -eq 0) { throw "Table 'companies' not found in database '$SourceDb'. Please ensure your dump contains this table." }
if ($CompanyIdOverride -and $CompanyIdOverride -gt 0) {
  $CompanyId = [int]$CompanyIdOverride
} else {
  $cid = Invoke-MySql -sql "SELECT id FROM companies WHERE name = '$cn' LIMIT 1" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
  if (-not $cid -or $cid.Count -eq 0) { $cid = Invoke-MySql -sql "SELECT id FROM companies WHERE company_name = '$cn' LIMIT 1" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb }
  if (-not $cid -or $cid.Count -eq 0) { $cid = Invoke-MySql -sql "SELECT id FROM companies WHERE name LIKE '%$cn%' LIMIT 1" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb }
  if (-not $cid -or $cid.Count -eq 0) { throw "Company not found" }
  $CompanyId = [int]$cid[0]
}
Write-Host "CompanyId $CompanyId"

$tablesCompanyId = Invoke-MySql -sql "SELECT TABLE_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='$SourceDb' AND COLUMN_NAME='company_id'" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
$tablesClientId = Invoke-MySql -sql "SELECT TABLE_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='$SourceDb' AND COLUMN_NAME='client_id'" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
$tablesProductId = Invoke-MySql -sql "SELECT TABLE_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='$SourceDb' AND COLUMN_NAME='product_id'" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb

$clientIds = Invoke-MySql -sql "SELECT id FROM clients WHERE company_id=$CompanyId" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
$productIds = Invoke-MySql -sql "SELECT id FROM products WHERE company_id=$CompanyId" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb

$clientIdList = if ($clientIds -and $clientIds.Count -gt 0) { ($clientIds | ForEach-Object { $_.Trim() } | Where-Object { $_ -ne "" }) -join "," } else { "" }
$productIdList = if ($productIds -and $productIds.Count -gt 0) { ($productIds | ForEach-Object { $_.Trim() } | Where-Object { $_ -ne "" }) -join "," } else { "" }

Write-Host "Clients $($clientIds.Count) Products $($productIds.Count)"

$tableConds = @{}
$tablesCompanyId | ForEach-Object { $tableConds[$_] = "company_id=$CompanyId" }
$tableConds["companies"] = "id=$CompanyId"
if ($tablesClientId) {
  $tablesClientId | ForEach-Object {
    if ($clientIdList -ne "") { $tableConds[$_] = "client_id IN ($clientIdList)" }
  }
}
if ($tablesProductId) {
  $tablesProductId | ForEach-Object {
    if ($productIdList -ne "") { $tableConds[$_] = "product_id IN ($productIdList)" }
  }
}

$fkRows = Invoke-MySql -sql "SELECT TABLE_NAME, COLUMN_NAME, REFERENCED_TABLE_NAME FROM INFORMATION_SCHEMA.KEY_COLUMN_USAGE WHERE TABLE_SCHEMA='$SourceDb' AND REFERENCED_TABLE_NAME IN ('companies','clients','products')" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
foreach ($row in $fkRows) {
  $parts = $row -split "`t"
  if ($parts.Count -ge 3) {
    $t = $parts[0]; $col = $parts[1]; $rt = $parts[2]
    if ($rt -eq "companies") { $tableConds[$t] = "$col=$CompanyId" }
    elseif ($rt -eq "clients" -and $clientIdList -ne "") { $tableConds[$t] = "$col IN ($clientIdList)" }
    elseif ($rt -eq "products" -and $productIdList -ne "") { $tableConds[$t] = "$col IN ($productIdList)" }
  }
}

$selectedTables = ($tableConds.Keys | Sort-Object -Unique)
if ($selectedTables.Count -eq 0) { throw "No related tables found" }

Write-Host "Tables $($selectedTables.Count)"
Remove-Item $OutputSql -ErrorAction SilentlyContinue
("SET FOREIGN_KEY_CHECKS=0;","DROP DATABASE IF EXISTS `$OutputDb`;","CREATE DATABASE `$OutputDb` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;","USE `$OutputDb`;") | Out-File -FilePath $OutputSql -Encoding ASCII

foreach ($t in $selectedTables) { Append-Mysqldump -table $t -where "" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb -outFile $OutputSql -StructureOnly }

foreach ($t in $selectedTables) {
  $cond = $tableConds[$t]
  try {
    $cnt = Invoke-MySql -sql "SELECT COUNT(*) FROM `$t` WHERE $cond" -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb
    Write-Host "$t rows $cnt"
  } catch {
    Write-Host "Count failed for $t"
  }
  Append-Mysqldump -table $t -where $cond -dbHost $SourceHost -dbPort $SourcePort -dbUser $SourceUser -dbPass $SourcePass -dbName $SourceDb -outFile $OutputSql
}

("SET FOREIGN_KEY_CHECKS=1;") | Out-File -FilePath $OutputSql -Append -Encoding ASCII

Write-Host "Output $OutputSql with database $OutputDb"
if ($TranscriptStarted) { try { Stop-Transcript | Out-Null } catch { } }
